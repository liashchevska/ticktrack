# Postgres
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Django
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=backend,localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

DJANGO_SECRET_KEY=dev-secret-key-not-secure

# db is a docker compose service name
DATABASE_HOST=db
DATABASE_PORT=5432

# Either set USE_CONSOLE_EMAIL_BACKEND to True
# or specify EMAIL_HOST_USER and EMAIL_HOST_PASSWORD
USE_CONSOLE_EMAIL_BACKEND=True
# EMAIL_HOST_USER=your-email
# EMAIL_HOST_PASSWORD=your-password